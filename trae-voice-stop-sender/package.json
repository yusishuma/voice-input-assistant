{
  "name": "voice-input-assistant",
  "displayName": "语音输入助手",
  "description": "语音输入助手：说话即可输入内容到 AI 对话。支持语音唤醒（默认\"小助小助\"）、停止词结束录音（默认\"完毕\"）、Vosk 离线识别、自动优化标点和粘贴到聊天输入框。完全免费，无需 API key。",
  "version": "2.0.0",
  "publisher": "yusishuma",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "语音",
    "voice",
    "speech",
    "麦克风",
    "语音输入",
    "语音唤醒",
    "AI对话",
    "聊天助手",
    "vosk",
    "python"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "commands": [
      {
        "command": "voiceStopSender.start",
        "title": "🎙 开始语音输入（说\"完毕\"结束）",
        "category": "语音输入助手"
      },
      {
        "command": "voiceStopSender.stop",
        "title": "⏹ 停止当前录音/唤醒",
        "category": "语音输入助手"
      },
      {
        "command": "voiceStopSender.configure",
        "title": "⚙ 设置停止词",
        "category": "语音输入助手"
      },
      {
        "command": "voiceStopSender.toggleWakeWord",
        "title": "👂 开启/关闭语音唤醒",
        "category": "语音输入助手"
      },
      {
        "command": "voiceStopSender.setWakeWord",
        "title": "🎯 设置语音唤醒词",
        "category": "语音输入助手"
      }
    ],
    "keybindings": [
      {
        "command": "voiceStopSender.start",
        "key": "ctrl+alt+v",
        "mac": "alt+v",
        "when": "!editorTextFocus"
      },
      {
        "command": "voiceStopSender.stop",
        "key": "escape",
        "mac": "escape",
        "when": "voiceStopSender.isRecording || voiceStopSender.isWakeListening"
      },
      {
        "command": "voiceStopSender.toggleWakeWord",
        "key": "ctrl+alt+shift+v",
        "mac": "alt+shift+v"
      },
      {
        "command": "voiceStopSender.configure",
        "key": "ctrl+alt+,",
        "mac": "alt+,"
      }
    ],
    "configuration": {
      "title": "语音输入助手",
      "properties": {
        "voiceStopSender.stopWord": {
          "type": "string",
          "default": "完毕",
          "description": "停止词。说出该词后立即停止录音，内容将被优化并发送到 AI 对话输入框。"
        },
        "voiceStopSender.wakeWord": {
          "type": "string",
          "default": "小助小助",
          "description": "语音唤醒词。默认启动后自动在后台监听，听到此词即开始录音。建议选择不易与日常用语混淆的 3–4 字词。"
        },
        "voiceStopSender.wakeWordEnabled": {
          "type": "boolean",
          "default": true,
          "description": "是否启用语音唤醒。启用后，扩展启动后会自动开启唤醒监听（持续后台监听，仅在录音时暂停），仅手动关闭才真正停止。"
        },
        "voiceStopSender.optimizeText": {
          "type": "boolean",
          "default": true,
          "description": "是否对识别后的文本进行标点/断句优化（去除空格、连接词前加逗号、句末补句号）。"
        },
        "voiceStopSender.replacements": {
          "type": "object",
          "default": {
            "小猪": "小助",
            "小猪小猪": "小助小助",
            "小猪小猪小": "小助小助",
            "小竹": "小助",
            "小竹小竹": "小助小助",
            "小雨": "小助",
            "小朱": "小助",
            "小主人": "小助"
          },
          "description": "同音词替换表。用于修复 Vosk 常见同音混淆。键是要替换的词，值是替换后的正确词。例如 {\"小猪\":\"小助\"}。"
        },
        "voiceStopSender.silenceTimeout": {
          "type": "number",
          "default": 3.0,
          "description": "静音超时（秒）。停止说话超过该时长后自动停止录音。设为 0 禁用（仅靠停止词结束）。"
        },
        "voiceStopSender.maxSeconds": {
          "type": "number",
          "default": 60,
          "description": "单次最长录音时长（秒）。防止忘记停止词导致持续录音。"
        },
        "voiceStopSender.pythonPath": {
          "type": "string",
          "default": "",
          "description": "自定义 Python 解释器路径（留空则自动检测：python3 / python / py）。需已安装 vosk、sounddevice、soundfile、numpy。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo 'ready'",
    "package": "npx --yes @vscode/vsce package --no-yarn --allow-star-activation"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0"
  }
}
